# Nocturne Production Environment 
# See: https://github.com/nightscout/nocturne/releases 
# 
# Copy this file to .env and fill in the required values. 
# Passwords are only used on first database initialization. 
 
# -- Configuration --------------------------------------------- 
NOCTURNE_API_IMAGE=ghcr.io/nightscout/nocturne/nocturne-api:latest
# Set this to a port not already in use within your environment 9020 for example
NOCTURNE_API_PORT=9020
NOCTURNE_WEB_IMAGE=ghcr.io/nightscout/nocturne/nocturne-web:latest
POSTGRES_USER=nocturne
POSTGRES_DB=nocturne
 
# -- Required (set these before first run) ---------------------- 
# Base URL that the Nocturne web site will be accessible on
BASE_DOMAIN=nocturne.local
# Instance key, should be long and complex. Only required in emergency recovery situations
INSTANCE_KEY=
POSTGRES_APP_PASSWORD=
POSTGRES_MIGRATOR_PASSWORD=
POSTGRES_PASSWORD= 
POSTGRES_WEB_PASSWORD= 
 
# -- Optional -------------------------------------------------- 
# Even if not configured leave these un-commented to avoid throwing WARN messages on docker compose up -d 
DISCORD_APPLICATION_ID= 
DISCORD_BOT_TOKEN= 
DISCORD_CLIENT_SECRET= 
DISCORD_PUBLIC_KEY= 
SLACK_BOT_TOKEN= 
SLACK_SIGNING_SECRET= 
TELEGRAM_BOT_TOKEN= 
TELEGRAM_WEBHOOK_SECRET_TOKEN= 
WHATSAPP_ACCESS_TOKEN= 
WHATSAPP_APP_SECRET= 
WHATSAPP_PHONE_NUMBER_ID= 
WHATSAPP_VERIFY_TOKEN=
