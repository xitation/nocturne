{
  // ==========================================================================
  // Aspire AppHost configuration.
  //
  // Copy to appsettings.json (or appsettings.Development.json) to use.
  // This file controls only the resource graph: which databases, services,
  // and optional integrations to spin up. Application-level config lives in
  // each project (src/API/Nocturne.API/appsettings.example.json,
  // src/Web/packages/app/.env.example).
  //
  // Secrets — Parameters:postgres-password, Parameters:instance-key, and the
  // chat bot tokens — should NOT live in this file. Set them via user-secrets
  // or environment variables:
  //
  //   dotnet user-secrets set "Parameters:instance-key" "$(openssl rand -hex 32)"
  //   dotnet user-secrets set "Parameters:postgres-password" "..."
  //   dotnet user-secrets set "Parameters:discord-bot-token" "..."
  //
  // Or via env: Parameters__instance-key=...
  // ==========================================================================

  // Orchestration: managed local PostgreSQL container vs external DB.
  // When true, fill in ConnectionStrings:nocturne-postgres below.
  "PostgreSql": {
    "UseRemoteDatabase": false
  },

  // Only used when PostgreSql:UseRemoteDatabase is true. All three strings
  // are required: the app role runs at request time with NOBYPASSRLS, the
  // migrator role owns the schema and runs migrations on startup, and the
  // web role is consumed by the SvelteKit bot state adapter (postgresql://
  // URL form). See docs/postgres/bootstrap-roles.sql to create the three
  // roles once per database.
  "ConnectionStrings": {
    "nocturne-postgres": "Host=localhost;Port=5432;Database=nocturne;Username=nocturne_app;Password=REPLACE_ME",
    "nocturne-postgres-migrator": "Host=localhost;Port=5432;Database=nocturne;Username=nocturne_migrator;Password=REPLACE_ME",
    "nocturne-postgres-web": "postgresql://nocturne_web:REPLACE_ME@localhost:5432/nocturne"
  },

  // Optional services to include in the resource graph.
  "Aspire": {
    "OptionalServices": {
      "AspireDashboard": { "Enabled": true },
      "Scalar":          { "Enabled": true },
      "Watchtower":      { "Enabled": false }
    }
  },

  // Non-secret parameter defaults. Aspire's AddParameter resolves these
  // from "Parameters:<name>" automatically.
  "Parameters": {
    "postgres-username": "nocturne_bootstrap",
    "postgres-database": "nocturne",
    "postgres-migrator-password": "dev-migrator-password-change-me",
    "postgres-app-password": "dev-app-password-change-me",
    "postgres-web-password": "dev-web-password-change-me"
    // postgres-password   — set via user-secrets
    // instance-key        — set via user-secrets
    // discord-bot-token   — set via user-secrets (optional)
    // discord-public-key  — set via user-secrets (optional; required for webhook signature verification)
    // discord-application-id — set via user-secrets (optional; required for OAuth2 Link-Discord flow)
    // discord-client-secret — set via user-secrets (optional; required for OAuth2 Link-Discord flow)
    // base-domain         — defaults to "localhost:1612"; set to e.g. "nocturne.run" in production
    // Discord OAuth2 state signing reuses instance-key — no separate HMAC secret.
    // telegram-bot-token  — set via user-secrets (optional)
    // slack-bot-token     — set via user-secrets (optional)
    // slack-signing-secret — set via user-secrets (optional)
    // whatsapp-access-token — set via user-secrets (optional)
    // whatsapp-verify-token — set via user-secrets (optional)
  }
}
