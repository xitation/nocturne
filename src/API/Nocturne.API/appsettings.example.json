{
  // ==========================================================================
  // Nocturne API configuration.
  //
  // Copy to appsettings.Development.json (or appsettings.json) to use.
  // Secrets (Oidc:Providers:*:ClientSecret, Loop:ApnsKey, Pushover:ApiToken,
  // etc.) should NOT live in this file — set them via user-secrets:
  //   dotnet user-secrets set "Oidc:Providers:0:ClientSecret" "..."
  // ==========================================================================

  "PostgreSql": {
    "EnableSensitiveDataLogging": false,
    "EnableDetailedErrors": false,
    "MaxRetryCount": 3,
    "MaxRetryDelaySeconds": 30,
    "CommandTimeoutSeconds": 30
  },

  // Authentication
  "Jwt": {
    "Issuer": "nocturne",
    "Audience": "nocturne-api",
    "AccessTokenLifetimeMinutes": 15,
    "RefreshTokenLifetimeDays": 7,
    "RefreshTokenLengthBytes": 64
  },

  "Oidc": {
    "Session": {
      "AccessTokenLifetime": "00:15:00",
      "RefreshTokenLifetime": "7.00:00:00",
      "RotateRefreshTokens": true
    },
    "Cookie": {
      "Domain": null,
      "Secure": true,
      "HttpOnly": true,
      "SameSite": "Lax"
    },
    "State": {
      "Lifetime": "00:15:00"
    },
    // Per-deployment OIDC providers. Client secrets via user-secrets.
    "Providers": []
  },

  // Base domain for subdomain tenant routing, WebAuthn, and URL construction
  "BASE_DOMAIN": "localhost:1612",

  // Predictions: None | DeviceStatus | OrefWasm
  "Predictions": {
    "Source": "None"
  },

  // Operator branding and self-service controls for managed/SaaS deployments
  "Operator": {
    "Name": null,
    "AllowSelfServiceCreation": true,
    "SlugValidationWebhookUrl": null,
    "UsernameValidationWebhookUrl": null,
    "Support": {
      "AccountBilling": null
    }
  },

  // Platform-level config for managed/SaaS deployments
  "Platform": {
    "AdminSubjectIds": []
  },

  // Loop / OpenAPS Push Notifications (Apple Push Notification Service)
  // ApnsKey, ApnsKeyId, DeveloperTeamId via user-secrets.
  "Loop": {
    "PushServerEnvironment": "development"
  },

  // Pushover Notifications
  // ApiToken, UserKey via user-secrets.
  "Pushover": {},

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.Hosting.Lifetime": "Information",
      "Microsoft.Extensions.Hosting": "Information",
      "Yarp": "Information",
      "Nocturne": "Information"
    },
    "Console": {
      "IncludeScopes": false,
      "LogLevel": {
        "Default": "Information"
      }
    }
  }
}
