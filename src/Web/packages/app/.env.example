# Web app environment.
#
# When running under `aspire start`, the AppHost injects PUBLIC_API_URL,
# NOCTURNE_API_URL, INSTANCE_KEY, OTEL_EXPORTER_OTLP_ENDPOINT, and any
# configured chat bot tokens automatically. You only need this file when
# running the web app standalone (`pnpm run dev` without Aspire).

PUBLIC_API_URL=http://localhost:1612
VITE_ENV=development

# Default UI language (ISO 639-1).
PUBLIC_DEFAULT_LANGUAGE=en

# OpenTelemetry collector. Leave blank to disable export.
OTEL_EXPORTER_OTLP_ENDPOINT=

# --- Secrets (do not commit) ---------------------------------------------
# Shared with API. Must match Parameters:instance-key in the AppHost config.
INSTANCE_KEY=your-instance-key-here

# Chat bot platform credentials are configured through the admin UI:
# Settings → Administration → Integrations
# Credentials are encrypted at rest. No env vars needed.
