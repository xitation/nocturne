{
  "name": "@nocturne/app",
  "version": "1.0.0",
  "type": "module",
  "main": "index.js",
  "exports": {
    "./src/app.css": "./src/app.css",
    "./ui/*.svelte": "./src/lib/components/ui/*.svelte",
    "./ui/*": "./src/lib/components/ui/*/index.ts",
    "./utils": "./src/lib/utils/index.ts",
    "./stores/*.svelte": "./src/lib/stores/*.svelte.ts",
    "./stores/*": "./src/lib/stores/*",
    "./components/*.svelte": "./src/lib/components/*.svelte",
    "./components/*": "./src/lib/components/*",
    "./api/*": "./src/lib/api/generated/*"
  },
  "directories": {
    "lib": "lib"
  },
  "author": "",
  "license": "AGPL-3.0-only",
  "description": "Nocturne SvelteKit frontend application",
  "scripts": {
    "start": "node server.js",
    "dev": "vite dev",
    "generate-api-client": "dotnet build -t:GenerateClient ../../../API/Nocturne.API/Nocturne.API.csproj",
    "generate:remote": "cd ../.. && npx openapi-remote-codegen",
    "dev:install": "pnpm install && pnpm run dev",
    "dev:install:fresh": "pnpm install --force && pnpm run dev",
    "dev:demo": "vite dev --mode demo",
    "dev:prod": "vite dev --mode production",
    "dev:test": "vite dev --mode test",
    "build": "vite build",
    "build:sveltekit": "vite build",
    "dev:sveltekit": "vite dev",
    "dev:sveltekit:prod": "vite dev --mode production",
    "dev:sveltekit:test": "vite dev --mode test",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check-native --tsconfig ./tsconfig.json 2>&1",
    "check:watch": "svelte-kit sync && svelte-check-native --tsconfig ./tsconfig.json --watch",
    "test:e2e": "playwright test",
    "test": "npm run test:e2e && npm run test:unit -- --run",
    "test:unit": "vitest --config vitest.config.ts",
    "test:browser": "vitest --config vitest.browser.config.ts",
    "lint": "eslint . && prettier --check .",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@internationalized/date": "^3.12.1",
    "@lucide/svelte": "^1.14.0",
    "@playwright/test": "^1.59.1",
    "@sveltejs/adapter-auto": "^7.0.1",
    "@sveltejs/adapter-node": "^5.5.4",
    "@sveltejs/kit": "^2.59.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.4",
    "@tanstack/table-core": "^8.21.3",
    "@types/d3-shape": "^3.1.8",
    "@types/d3-time": "^3.0.4",
    "@types/eslint": "^9.6.1",
    "@typescript/native-preview": "7.0.0-dev.20260504.1",
    "@vitest/browser-playwright": "^4.1.5",
    "autoprefixer": "^10.5.0",
    "bits-ui": "^2.18.1",
    "clsx": "^2.1.1",
    "diff": "^9.0.0",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-svelte": "^3.17.1",
    "globals": "^17.6.0",
    "happy-dom": "^20.9.0",
    "layerchart": "2.0.0-next.43",
    "mode-watcher": "^1.1.0",
    "openapi-remote-codegen": "0.2.0",
    "paneforge": "^1.0.2",
    "prettier": "^3.8.3",
    "prettier-plugin-jsdoc": "^1.8.0",
    "prettier-plugin-svelte": "^3.5.1",
    "socket.io-client": "^4.8.3",
    "svelte": "^5.55.5",
    "svelte-check-native": "^0.8.2",
    "svelte-sonner": "^1.1.1",
    "sveltekit-superforms": "^2.30.1",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.1.7",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.59.2",
    "vaul-svelte": "1.0.0-next.7",
    "vite": "^8.0.10",
    "vite-plugin-commonjs": "^0.10.4",
    "vitest": "^4.1.5",
    "vitest-browser-svelte": "^2.1.1"
  },
  "dependencies": {
    "@nocturne/bot": "workspace:*",
    "@nocturne/bridge": "workspace:*",
    "@nocturne/coach": "workspace:*",
    "@nocturne/ui": "workspace:*",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.74.0",
    "@opentelemetry/exporter-trace-otlp-grpc": "^0.216.0",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-node": "^0.216.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@simplewebauthn/browser": "^13.3.0",
    "@types/d3": "^7.4.3",
    "@types/d3-scale": "^4.0.9",
    "@types/qrcode": "^1.5.6",
    "d3": "^7.9.0",
    "d3-scale": "^4.0.2",
    "d3-shape": "^3.2.0",
    "d3-time": "^3.1.0",
    "import-in-the-middle": "^3.0.1",
    "lucide-svelte": "^1.0.1",
    "qrcode": "^1.5.4",
    "runed": "^0.37.1",
    "sveltekit-search-params": "^3.0.0",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "zod": "^4.4.3"
  }
}
